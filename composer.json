{
    "name": "hdrm147/price-checker",
    "description": "Competitor price tracking — Eloquent + Nova Tool + stateless scraper service",
    "keywords": [
        "laravel",
        "nova",
        "price-checker",
        "scraping"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/bus": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/queue": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/nova": "^5.0",
        "laravel/nova-devtool": "^1.8"
    },
    "repositories": [
        { "type": "composer", "url": "https://nova.laravel.com" }
    ],
    "autoload": {
        "psr-4": {
            "Hdrm147\\PriceChecker\\": "src/",
            "Hdrm147\\PriceChecker\\Database\\Factories\\": "database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hdrm147\\PriceChecker\\PriceCheckerServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
